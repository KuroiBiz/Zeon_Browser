{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeon Browser",
  "version": "1.0.0",
  "identifier": "dev.kuroi.zeonbrowser",
  "description": "Light as a paper",

  "build": {
    "frontendDist": "../src"
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zeon Browser",
        "width": 800,
        "height": 600,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
